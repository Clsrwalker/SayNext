PORT=3000
PACKAGE_NAME=com.xiangli.saynext.dev
MENTRAOS_API_KEY=your_mentraos_api_key_here
COOKIE_SECRET=replace_with_long_random_secret

LLM_PROVIDER=ollama
# Default live answer model. This path must stay very fast.
OPENAI_MODEL=gpt-5.4-nano
# Long/high-risk teleprompt model. Kept separate so live answers do not get slower.
OPENAI_LONG_MODEL=gpt-5.4-mini
# OpenAI session conversation state is the travel-mode default.
# Local mode keeps it false unless actively A/B testing.
OPENAI_CONVERSATION_STATE_ENABLED=false
OPENAI_CONVERSATION_KEEP_ASSISTANT_OUTPUTS=false
OPENAI_CONVERSATION_WARMUP_TIMEOUT_MS=8000
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:14b-instruct
OLLAMA_TIMEOUT_MS=30000

PIPELINE_OLLAMA_MODEL=qwen2.5:14b-instruct
PIPELINE_OLLAMA_TIMEOUT_MS=90000
PERSONALIZATION_PIPELINE_ENABLED=false

DATA_LOGGING_ENABLED=true
SAYNEXT_DB_PATH=/data/saynext.sqlite

# Runtime mode:
# For VPS travel mode, set:
# SAYNEXT_RUNTIME_MODE=travel
# LLM_PROVIDER=openai
# OPENAI_API_KEY=...
# Session memory extraction is synchronous OpenAI in travel mode; batch stays disabled.
SAYNEXT_RUNTIME_MODE=local
SESSION_MEMORY_PROVIDER=ollama
SESSION_MEMORY_BATCH_ENABLED=false
SESSION_MEMORY_OPENAI_MODEL=gpt-4.1-mini
SESSION_MEMORY_OPENAI_TIMEOUT_MS=180000

SERPAPI_API_KEY=
GOOGLE_MAPS_API_KEY=
GOOGLE_WEATHER_API_KEY=
